{
  "name": "expo-web-template",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --web",
    "web": "expo start --web",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "predeploy": "expo export -p web && shx touch dist/.gitignore && shx cp dist/index.html dist/404.html",
    "deploy": "gh-pages --nojekyll -d dist -t",
    "new-site": "node scripts/new-site.js"
  },
  "dependencies": {
    "@types/react": "~19.1.10",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.8",
    "expo-splash-screen": "~31.0.9",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~6.0.7",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "shx": "^0.4.0",
    "typescript": "~5.9.0"
  }
}
